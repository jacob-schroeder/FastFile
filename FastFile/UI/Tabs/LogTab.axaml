<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="UI.Tabs.LogTab">
    <Border Margin="0"
            Padding="0"
            CornerRadius="0"
            Background="#2B2D30"
            BorderBrush="#4E5157"
            BorderThickness="1">
        <ScrollViewer Margin="18"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
            <Border Classes="logOutput">
                <TextBlock x:Name="LogTextBlock"
                           Classes="logText"
                           Text="Open a fastfile to view parse output." />
            </Border>
        </ScrollViewer>
    </Border>
</UserControl>
