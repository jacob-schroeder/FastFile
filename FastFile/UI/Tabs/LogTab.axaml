<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="UI.Tabs.LogTab">
    <Border Margin="22"
            Padding="0"
            CornerRadius="14"
            Background="#B8FFFFFF"
            BorderBrush="#70A8D7FF"
            BorderThickness="1">
        <ScrollViewer Margin="18"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
            <Border Classes="logOutput">
                <TextBlock x:Name="LogTextBlock"
                           Classes="logText"
                           Text="Open a fastfile to view parse output." />
            </Border>
        </ScrollViewer>
    </Border>
</UserControl>
