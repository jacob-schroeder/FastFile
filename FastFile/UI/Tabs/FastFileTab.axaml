<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="UI.Tabs.FastFileTab">
    <Grid RowDefinitions="Auto,*" Margin="12">
        <StackPanel Spacing="6">
            <TextBlock Text="FastFile"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#11345D" />
            <TextBlock x:Name="StatusTextBlock"
                       Text="Open a fastfile to inspect its zone assets."
                       FontSize="14"
                       Foreground="#5B6F88"
                       TextWrapping="Wrap" />
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,20,0,0"
                Padding="0"
                CornerRadius="14"
                Background="#B8FFFFFF"
                BorderBrush="#70A8D7FF"
                BorderThickness="1">
            <Border Classes="listGroup"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top"
                    Margin="18">
                <StackPanel>
                    <Border Classes="listGroupItem">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Classes="listGroupLabel" Text="Magic" />
                            <Border Grid.Column="1" Classes="badge">
                                <TextBlock x:Name="MagicValueTextBlock"
                                           Classes="badgeText"
                                           Text="-" />
                            </Border>
                        </Grid>
                    </Border>

                    <Border Classes="listGroupItem">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Classes="listGroupLabel" Text="Version" />
                            <Border Grid.Column="1" Classes="badge">
                                <TextBlock x:Name="VersionValueTextBlock"
                                           Classes="badgeText"
                                           Text="-" />
                            </Border>
                        </Grid>
                    </Border>

                    <Border Classes="listGroupItem listGroupItemLast">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Classes="listGroupLabel" Text="Size" />
                            <Border Grid.Column="1" Classes="badge">
                                <TextBlock x:Name="SizeValueTextBlock"
                                           Classes="badgeText"
                                           Text="-" />
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
