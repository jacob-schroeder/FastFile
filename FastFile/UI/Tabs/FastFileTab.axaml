<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:UI.Models"
             x:Class="UI.Tabs.FastFileTab">
    <Grid RowDefinitions="Auto,*" Margin="0">
        <StackPanel Spacing="6">
            <TextBlock x:Name="StatusTextBlock"
                       Text="Open a fastfile to inspect its zone assets."
                       FontSize="14"
                       Foreground="#BFC0C9"
                       TextWrapping="Wrap" />
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0"
                Padding="0"
                CornerRadius="0"
                Background="#2B2D30"
                BorderBrush="#4E5157"
                BorderThickness="1">
            <ScrollViewer Margin="18"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <Border Classes="listGroup"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Top">
                    <ItemsControl x:Name="HeaderItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:KeyValueListItem">
                                <Border Classes="listGroupItem">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Classes="listGroupLabel"
                                                   Text="{Binding Key}" />
                                        <Border Grid.Column="1" Classes="badge">
                                            <TextBlock Classes="badgeText"
                                                       Text="{Binding Value}" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
