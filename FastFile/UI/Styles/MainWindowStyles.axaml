<Styles xmlns="https://github.com/avaloniaui">
    <Style Selector="Menu.mainMenu">
        <Setter Property="Height" Value="34" />
        <Setter Property="Padding" Value="8,0" />
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Color="#2F8CFF" Offset="0" />
                <GradientStop Color="#06438F" Offset="1" />
            </LinearGradientBrush>
        </Setter>
    </Style>

    <Style Selector="MenuItem.topMenuItem">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TabControl.mainTabs">
        <Setter Property="Margin" Value="16" />
        <Setter Property="Background" Value="#7AFFFFFF" />
    </Style>

    <Style Selector="TabItem">
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="2,0,2,0" />
    </Style>

    <Style Selector="Border.tabHeader">
        <Setter Property="MinWidth" Value="96" />
        <Setter Property="Padding" Value="16,9" />
        <Setter Property="CornerRadius" Value="8,8,0,0" />
        <Setter Property="BorderBrush" Value="#8BB9E9" />
        <Setter Property="BorderThickness" Value="1,1,1,0" />
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Color="#F8FBFF" Offset="0" />
                <GradientStop Color="#DDEEFF" Offset="1" />
            </LinearGradientBrush>
        </Setter>
    </Style>

    <Style Selector="TextBlock.tabHeaderText">
        <Setter Property="Foreground" Value="#111827" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style Selector="TabItem:pointerover Border.tabHeader">
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Color="#EAF4FF" Offset="0" />
                <GradientStop Color="#C9E2FF" Offset="1" />
            </LinearGradientBrush>
        </Setter>
        <Setter Property="BorderBrush" Value="#06438F" />
    </Style>

    <Style Selector="TabItem:pointerover TextBlock.tabHeaderText">
        <Setter Property="Foreground" Value="#06438F" />
    </Style>

    <Style Selector="TabItem:selected Border.tabHeader">
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Color="#FFFFFF" Offset="0" />
                <GradientStop Color="#D8ECFF" Offset="1" />
            </LinearGradientBrush>
        </Setter>
        <Setter Property="BorderBrush" Value="#2F8CFF" />
    </Style>

    <Style Selector="TabItem:selected TextBlock.tabHeaderText">
        <Setter Property="Foreground" Value="#06438F" />
    </Style>

    <Style Selector="Border.listGroup">
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="#DEE2E6" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Border.listGroupItem">
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="#DEE2E6" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style Selector="Border.listGroupItemLast">
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="TextBlock.listGroupLabel">
        <Setter Property="Foreground" Value="#212529" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.badge">
        <Setter Property="MinWidth" Value="48" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="CornerRadius" Value="999" />
        <Setter Property="Background" Value="#0D6EFD" />
    </Style>

    <Style Selector="TextBlock.badgeText">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.badgeDanger">
        <Setter Property="MinWidth" Value="36" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="CornerRadius" Value="999" />
        <Setter Property="Background" Value="#DC3545" />
    </Style>

    <Style Selector="Border.assetTreeCountBadge">
        <Setter Property="MinWidth" Value="28" />
        <Setter Property="Padding" Value="8,2" />
        <Setter Property="CornerRadius" Value="999" />
        <Setter Property="Background" Value="#DC3545" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.assetTreeCountBadgeText">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.accordion">
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="#DEE2E6" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style Selector="Border.accordionItem">
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="#DEE2E6" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style Selector="Border.accordionItemLast">
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="Button.accordionHeaderButton">
        <Setter Property="Padding" Value="22,14" />
        <Setter Property="Background" Value="#F8F9FA" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="Button.accordionHeaderButton:pointerover">
        <Setter Property="Background" Value="#E7F1FF" />
    </Style>

    <Style Selector="Border.accordionBody">
        <Setter Property="Padding" Value="16" />
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="#DEE2E6" />
        <Setter Property="BorderThickness" Value="0,1,0,0" />
    </Style>

    <Style Selector="Border.assetTree">
        <Setter Property="Background" Value="#1E1F22" />
        <Setter Property="BorderBrush" Value="#393B40" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style Selector="TextBlock.assetTreeHeader">
        <Setter Property="Foreground" Value="#F3F4F6" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.assetTreeFolderButton">
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="Button.assetTreeFolderButton:pointerover">
        <Setter Property="Background" Value="#2B2D31" />
    </Style>

    <Style Selector="TextBlock.assetTreeText">
        <Setter Property="Foreground" Value="#E5E7EB" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.assetTreeMutedText">
        <Setter Property="Foreground" Value="#9CA3AF" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.assetTreeAssetRow">
        <Setter Property="Padding" Value="32,0,0,0" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="Button.assetTreeAssetButton">
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Padding" Value="14,7,10,7" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="Button.assetTreeAssetButton:pointerover">
        <Setter Property="Background" Value="#2B2D31" />
    </Style>

    <Style Selector="Border.assetDetailHost">
        <Setter Property="Background" Value="#F8FBFF" />
        <Setter Property="BorderBrush" Value="#70A8D7FF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="14" />
    </Style>

    <Style Selector="StackPanel.assetTreeGroup">
        <Setter Property="Margin" Value="0,4" />
    </Style>

    <Style Selector="Border.logOutput">
        <Setter Property="Background" Value="#111827" />
        <Setter Property="BorderBrush" Value="#334155" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="14" />
    </Style>

    <Style Selector="TextBlock.logText">
        <Setter Property="Foreground" Value="#E5E7EB" />
        <Setter Property="FontFamily" Value="Courier New" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="LineHeight" Value="20" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style Selector="Button.actionButton">
        <Setter Property="Width" Value="28" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="5" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="Button.actionButtonDanger">
        <Setter Property="Background" Value="#DC3545" />
        <Setter Property="BorderBrush" Value="#DC3545" />
    </Style>

    <Style Selector="Button.actionButtonDanger:pointerover">
        <Setter Property="Background" Value="#BB2D3B" />
        <Setter Property="BorderBrush" Value="#B02A37" />
    </Style>

    <Style Selector="Button.actionButtonPrimary">
        <Setter Property="Background" Value="#0D6EFD" />
        <Setter Property="BorderBrush" Value="#0D6EFD" />
    </Style>

    <Style Selector="Button.actionButtonPrimary:pointerover">
        <Setter Property="Background" Value="#0B5ED7" />
        <Setter Property="BorderBrush" Value="#0A58CA" />
    </Style>

    <Style Selector="Button.actionButtonSuccess">
        <Setter Property="Background" Value="#198754" />
        <Setter Property="BorderBrush" Value="#198754" />
    </Style>

    <Style Selector="Button.actionButtonSuccess:pointerover">
        <Setter Property="Background" Value="#157347" />
        <Setter Property="BorderBrush" Value="#146C43" />
    </Style>
</Styles>
