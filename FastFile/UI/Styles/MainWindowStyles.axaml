<Styles xmlns="https://github.com/avaloniaui">
    <Style Selector="Menu.mainMenu">
        <Setter Property="Height" Value="34" />
        <Setter Property="Padding" Value="8,0" />
        <Setter Property="Background" Value="#2B2D30" />
    </Style>

    <Style Selector="MenuItem.topMenuItem">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TabControl.mainTabs">
        <Setter Property="Margin" Value="0" />
        <Setter Property="Background" Value="#1E1F22" />
        <Setter Property="IndicatorTemplate">
            <DataTemplate>
                <Border Height="0"
                        Background="Transparent" />
            </DataTemplate>
        </Setter>
    </Style>

    <Style Selector="TabItem">
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="IndicatorTemplate">
            <DataTemplate>
                <Border Height="0"
                        Background="Transparent" />
            </DataTemplate>
        </Setter>
    </Style>

    <Style Selector="Border.tabHeader">
        <Setter Property="MinWidth" Value="96" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="BorderBrush" Value="#4E5157" />
        <Setter Property="BorderThickness" Value="1,1,1,0" />
        <Setter Property="Background" Value="#252629" />
    </Style>

    <Style Selector="TextBlock.tabHeaderText">
        <Setter Property="Foreground" Value="#C7C9D1" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="16,9,16,8" />
    </Style>

    <Style Selector="Border.tabHeaderSelectedBar">
        <Setter Property="Height" Value="7" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style Selector="TabItem:pointerover Border.tabHeader">
        <Setter Property="Background" Value="#323438" />
        <Setter Property="BorderBrush" Value="#DB5860" />
    </Style>

    <Style Selector="TabItem:pointerover TextBlock.tabHeaderText">
        <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>

    <Style Selector="TabItem:selected Border.tabHeader">
        <Setter Property="Background" Value="#3A3D42" />
        <Setter Property="BorderBrush" Value="#DB5860" />
    </Style>

    <Style Selector="TabItem:selected TextBlock.tabHeaderText">
        <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>

    <Style Selector="TabItem:selected Border.tabHeaderSelectedBar">
        <Setter Property="Background" Value="#DB5860" />
    </Style>

    <Style Selector="Border.listGroup">
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Background" Value="#252629" />
        <Setter Property="BorderBrush" Value="#4E5157" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Border.listGroupItem">
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="Background" Value="#252629" />
        <Setter Property="BorderBrush" Value="#3C3F44" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style Selector="Border.listGroupItemLast">
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="TextBlock.listGroupLabel">
        <Setter Property="Foreground" Value="#F4F4F5" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBox">
        <Setter Property="Background" Value="#1E1F22" />
        <Setter Property="BorderBrush" Value="#4E5157" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Foreground" Value="#F4F4F5" />
        <Setter Property="SelectionBrush" Value="#7B3137" />
    </Style>

    <Style Selector="Border.badge">
        <Setter Property="MinWidth" Value="48" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="CornerRadius" Value="999" />
        <Setter Property="Background" Value="#9E3A3F" />
    </Style>

    <Style Selector="TextBlock.badgeText">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.badgeDanger">
        <Setter Property="MinWidth" Value="36" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="CornerRadius" Value="999" />
        <Setter Property="Background" Value="#DB5860" />
    </Style>

    <Style Selector="Border.assetTreeCountBadge">
        <Setter Property="MinWidth" Value="28" />
        <Setter Property="Padding" Value="8,2" />
        <Setter Property="CornerRadius" Value="999" />
        <Setter Property="Background" Value="#DB5860" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.assetTreeCountBadgeText">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.accordion">
        <Setter Property="Background" Value="#252629" />
        <Setter Property="BorderBrush" Value="#4E5157" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <Style Selector="Border.accordionItem">
        <Setter Property="Background" Value="#252629" />
        <Setter Property="BorderBrush" Value="#3C3F44" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style Selector="Border.accordionItemLast">
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="Button.accordionHeaderButton">
        <Setter Property="Padding" Value="22,14" />
        <Setter Property="Background" Value="#2B2D30" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="Button.accordionHeaderButton:pointerover">
        <Setter Property="Background" Value="#3A3D42" />
    </Style>

    <Style Selector="Border.accordionBody">
        <Setter Property="Padding" Value="16" />
        <Setter Property="Background" Value="#252629" />
        <Setter Property="BorderBrush" Value="#3C3F44" />
        <Setter Property="BorderThickness" Value="0,1,0,0" />
    </Style>

    <Style Selector="Border.assetTree">
        <Setter Property="Background" Value="#252629" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <Style Selector="TextBlock.assetTreeHeader">
        <Setter Property="Foreground" Value="#F3F4F6" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.assetTreeFolderButton">
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="Button.assetTreeFolderButton:pointerover">
        <Setter Property="Background" Value="#3A3D42" />
    </Style>

    <Style Selector="TextBlock.assetTreeText">
        <Setter Property="Foreground" Value="#E5E7EB" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.assetTreeMutedText">
        <Setter Property="Foreground" Value="#9CA3AF" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.assetTreeAssetRow">
        <Setter Property="Padding" Value="32,0,0,0" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="Button.assetTreeAssetButton">
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Padding" Value="14,7,10,7" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="Button.assetTreeAssetButton:pointerover">
        <Setter Property="Background" Value="#3A3D42" />
    </Style>

    <Style Selector="Border.assetDetailHost">
        <Setter Property="Background" Value="#1E1F22" />
        <Setter Property="BorderBrush" Value="#4E5157" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="ClipToBounds" Value="True" />
    </Style>

    <Style Selector="Border.assetDetailTabStrip">
        <Setter Property="Background" Value="#252629" />
        <Setter Property="BorderBrush" Value="#4E5157" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="6,6,6,0" />
    </Style>

    <Style Selector="Border.assetDetailTabHeader">
        <Setter Property="MinWidth" Value="128" />
        <Setter Property="MaxWidth" Value="260" />
        <Setter Property="Height" Value="34" />
        <Setter Property="Margin" Value="0,0,4,0" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <Style Selector="Button.assetDetailTabSelectButton">
        <Setter Property="Padding" Value="10,6,4,6" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.assetDetailTabTitle">
        <Setter Property="Foreground" Value="#F4F4F5" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.assetDetailTabCloseButton">
        <Setter Property="Width" Value="22" />
        <Setter Property="Height" Value="22" />
        <Setter Property="Margin" Value="0,5,6,5" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Foreground" Value="#C7C9D1" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.assetDetailTabCloseButton:pointerover">
        <Setter Property="Background" Value="#4A2B2F" />
        <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>

    <Style Selector="StackPanel.assetTreeGroup">
        <Setter Property="Margin" Value="0,4" />
    </Style>

    <Style Selector="Border.logOutput">
        <Setter Property="Background" Value="#1E1F22" />
        <Setter Property="BorderBrush" Value="#4E5157" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="14" />
    </Style>

    <Style Selector="TextBlock.logText">
        <Setter Property="Foreground" Value="#E5E7EB" />
        <Setter Property="FontFamily" Value="Courier New" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="LineHeight" Value="20" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style Selector="Button.actionButton">
        <Setter Property="Width" Value="28" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="Button.actionButtonDanger">
        <Setter Property="Background" Value="#DB5860" />
        <Setter Property="BorderBrush" Value="#DB5860" />
    </Style>

    <Style Selector="Button.actionButtonDanger:pointerover">
        <Setter Property="Background" Value="#B43F46" />
        <Setter Property="BorderBrush" Value="#B43F46" />
    </Style>

    <Style Selector="Button.actionButtonPrimary">
        <Setter Property="Background" Value="#9E3A3F" />
        <Setter Property="BorderBrush" Value="#9E3A3F" />
    </Style>

    <Style Selector="Button.actionButtonPrimary:pointerover">
        <Setter Property="Background" Value="#B43F46" />
        <Setter Property="BorderBrush" Value="#B43F46" />
    </Style>

    <Style Selector="Button.actionButtonSuccess">
        <Setter Property="Background" Value="#3A3D42" />
        <Setter Property="BorderBrush" Value="#DB5860" />
    </Style>

    <Style Selector="Button.actionButtonSuccess:pointerover">
        <Setter Property="Background" Value="#4A2B2F" />
        <Setter Property="BorderBrush" Value="#DB5860" />
    </Style>
</Styles>
