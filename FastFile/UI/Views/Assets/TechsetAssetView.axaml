<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:UI.Models"
             x:Class="UI.Views.Assets.TechsetAssetView">
    <UserControl.Styles>
        <Style Selector="TextBlock.techsetTitle">
            <Setter Property="Foreground" Value="#F4F4F5" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBlock.techsetMeta">
            <Setter Property="Foreground" Value="#C7C9D1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style Selector="TextBlock.techsetSectionTitle">
            <Setter Property="Foreground" Value="#F4F4F5" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBlock.techsetKey">
            <Setter Property="Foreground" Value="#9DA1AA" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBlock.techsetValue">
            <Setter Property="Foreground" Value="#E5E7EB" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style Selector="TextBlock.techsetSecondary">
            <Setter Property="Foreground" Value="#B6BBC6" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style Selector="TextBlock.techsetTechniqueTitle">
            <Setter Property="Foreground" Value="#F4F4F5" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style Selector="TextBlock.techsetTechniqueMeta">
            <Setter Property="Foreground" Value="#8F949E" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="HorizontalAlignment" Value="Right" />
        </Style>

        <Style Selector="Border.techsetPanel">
            <Setter Property="Background" Value="#252629" />
            <Setter Property="BorderBrush" Value="#3C3F44" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="0" />
        </Style>

        <Style Selector="Border.techsetHeader">
            <Setter Property="Background" Value="#2B2D30" />
            <Setter Property="BorderBrush" Value="#3C3F44" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="12,10" />
        </Style>

        <Style Selector="Border.techsetValueRow">
            <Setter Property="BorderBrush" Value="#34373D" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="12,8" />
        </Style>

        <Style Selector="Border.techsetTechniqueCard">
            <Setter Property="Background" Value="#24272D" />
            <Setter Property="BorderBrush" Value="#3C3F44" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style Selector="Border.techsetPassCard">
            <Setter Property="BorderBrush" Value="#32373E" />
            <Setter Property="BorderThickness" Value="0,1,0,0" />
            <Setter Property="Padding" Value="8,8,8,10" />
        </Style>

        <Style Selector="TextBlock.techsetPassLabel">
            <Setter Property="Foreground" Value="#A8ADBA" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBlock.techsetPassValue">
            <Setter Property="Foreground" Value="#D5DAE6" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
    </UserControl.Styles>

    <Grid>
        <Grid RowDefinitions="Auto,*"
              Background="#1E1F22">
            <Border Padding="14,12"
                    Background="#252629"
                    BorderBrush="#3C3F44"
                    BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="12">
                    <StackPanel Spacing="3">
                        <TextBlock x:Name="TechsetNameTextBlock"
                                   Classes="techsetTitle" />
                        <TextBlock x:Name="TechsetSummaryTextBlock"
                                   Classes="techsetMeta" />
                    </StackPanel>

                    <TextBlock x:Name="TechsetTechniqueCountTextBlock"
                               Grid.Column="1"
                               Classes="techsetMeta"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <Grid Margin="14"
                      RowDefinitions="Auto,Auto"
                      RowSpacing="12">
                    <Border Classes="techsetPanel">
                        <Grid RowDefinitions="Auto,*">
                            <Border Classes="techsetHeader">
                                <TextBlock Classes="techsetSectionTitle"
                                           Text="Techset Details" />
                            </Border>

                            <ItemsControl x:Name="TechsetSummaryItemsControl"
                                          Grid.Row="1">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:KeyValueListItem">
                                        <Border Classes="techsetValueRow">
                                            <Grid ColumnDefinitions="Auto,*"
                                                  ColumnSpacing="12">
                                                <TextBlock Classes="techsetKey"
                                                           Text="{Binding Key}" />
                                                <TextBlock Grid.Column="1"
                                                           Classes="techsetValue"
                                                           IsVisible="{Binding HasNoNavigationTarget}"
                                                           Text="{Binding Value}" />
                                                <Button Grid.Column="1"
                                                        Classes="blockStreamNavigationLabel"
                                                        Content="{Binding NavigationValue}"
                                                        Tag="{Binding NavigationTarget}"
                                                        IsVisible="{Binding HasNavigationTarget}"
                                                        Click="BlockStreamNavigationButton_Click" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Classes="techsetPanel">
                        <Grid RowDefinitions="Auto,*">
                            <Border Classes="techsetHeader">
                                <TextBlock Classes="techsetSectionTitle"
                                           Text="Techniques" />
                            </Border>

                            <Grid Grid.Row="1"
                                  RowDefinitions="Auto,Auto">
                                <ItemsControl x:Name="TechsetTechniquesItemsControl">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:TechsetTechniqueDisplayItem">
                                            <Border Classes="techsetTechniqueCard">
                                                <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                                                      RowSpacing="10">
                                                    <Grid ColumnDefinitions="*,Auto"
                                                          ColumnSpacing="10">
                                                        <TextBlock Classes="techsetTechniqueTitle"
                                                                   Text="{Binding Name}" />
                                                        <TextBlock Grid.Column="1"
                                                                   Classes="techsetTechniqueMeta"
                                                                   IsVisible="{Binding HasNoPointerNavigationTarget}"
                                                                   Text="{Binding Pointer}" />
                                                        <Button Grid.Column="1"
                                                                Classes="blockStreamNavigationLabel"
                                                                Content="{Binding PointerNavigationValue}"
                                                                Tag="{Binding PointerNavigationTarget}"
                                                                IsVisible="{Binding HasPointerNavigationTarget}"
                                                                Click="BlockStreamNavigationButton_Click" />
                                                    </Grid>

                                                    <Grid Grid.Row="1"
                                                          ColumnDefinitions="80,*,70,120"
                                                          ColumnSpacing="10">
                                                        <TextBlock Classes="techsetSecondary"
                                                                   Text="Slot" />
                                                        <TextBlock Grid.Column="1"
                                                                   Classes="techsetPassValue"
                                                                   Text="{Binding SlotText}" />
                                                        <TextBlock Grid.Column="2"
                                                                   Classes="techsetSecondary"
                                                                   Text="Flags" />
                                                        <TextBlock Grid.Column="3"
                                                                   Classes="techsetPassValue"
                                                                   Text="{Binding Flags}" />
                                                    </Grid>

                                                    <Grid Grid.Row="2"
                                                          ColumnDefinitions="80,*,120"
                                                          ColumnSpacing="10">
                                                        <TextBlock Classes="techsetSecondary"
                                                                   Text="Passes" />
                                                        <TextBlock Grid.Column="1"
                                                                   Classes="techsetPassValue"
                                                                   Text="{Binding PassCount}" />
                                                        <TextBlock Grid.Column="2"
                                                                   Classes="techsetPassValue"
                                                                   Text="{Binding PassesIndicator}" />
                                                    </Grid>

                                                    <StackPanel Grid.Row="3"
                                                                Spacing="6">
                                                        <TextBlock Classes="techsetSecondary"
                                                                   Text="Passes Detail"
                                                                   IsVisible="{Binding HasPasses}" />

                                                        <TextBlock Classes="techsetPassValue"
                                                                   Text="No passes were resolved for this technique."
                                                                   IsVisible="{Binding HasNoPasses}" />

                                                        <ItemsControl ItemsSource="{Binding Passes}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate x:DataType="models:TechsetPassDisplayItem">
                                                                    <Border Classes="techsetPassCard">
                                                                        <StackPanel Spacing="6">
                                                                            <Grid ColumnDefinitions="Auto,*"
                                                                                  ColumnSpacing="10">
                                                                                <TextBlock Classes="techsetPassLabel"
                                                                                           Text="{Binding IndexText}" />
                                                                                <TextBlock Grid.Column="1"
                                                                                           Classes="techsetPassValue"
                                                                                           Text="{Binding ArgumentSummary}" />
                                                                            </Grid>

                                                                            <Grid ColumnDefinitions="100,*"
                                                                                  ColumnSpacing="10">
                                                                                <TextBlock Classes="techsetPassLabel"
                                                                                           Text="Vertex Decl" />
                                                                                <TextBlock Grid.Column="1"
                                                                                           Classes="techsetPassValue"
                                                                                           IsVisible="{Binding HasNoVertexDeclarationNavigationTarget}"
                                                                                           Text="{Binding VertexDeclaration}" />
                                                                                <Button Grid.Column="1"
                                                                                        Classes="blockStreamNavigationLabel"
                                                                                        Content="{Binding VertexDeclarationNavigationValue}"
                                                                                        Tag="{Binding VertexDeclarationNavigationTarget}"
                                                                                        IsVisible="{Binding HasVertexDeclarationNavigationTarget}"
                                                                                        Click="BlockStreamNavigationButton_Click" />
                                                                            </Grid>

                                                                            <Grid ColumnDefinitions="100,*"
                                                                                  ColumnSpacing="10">
                                                                                <TextBlock Classes="techsetPassLabel"
                                                                                           Text="Vertex Shader" />
                                                                                <TextBlock Grid.Column="1"
                                                                                           Classes="techsetPassValue"
                                                                                           IsVisible="{Binding HasNoVertexShaderNavigationTarget}"
                                                                                           Text="{Binding VertexShader}" />
                                                                                <Button Grid.Column="1"
                                                                                        Classes="blockStreamNavigationLabel"
                                                                                        Content="{Binding VertexShaderNavigationValue}"
                                                                                        Tag="{Binding VertexShaderNavigationTarget}"
                                                                                        IsVisible="{Binding HasVertexShaderNavigationTarget}"
                                                                                        Click="BlockStreamNavigationButton_Click" />
                                                                            </Grid>

                                                                            <Grid ColumnDefinitions="100,*"
                                                                                  ColumnSpacing="10">
                                                                                <TextBlock Classes="techsetPassLabel"
                                                                                           Text="Pixel Shader" />
                                                                                <TextBlock Grid.Column="1"
                                                                                           Classes="techsetPassValue"
                                                                                           IsVisible="{Binding HasNoPixelShaderNavigationTarget}"
                                                                                           Text="{Binding PixelShader}" />
                                                                                <Button Grid.Column="1"
                                                                                        Classes="blockStreamNavigationLabel"
                                                                                        Content="{Binding PixelShaderNavigationValue}"
                                                                                        Tag="{Binding PixelShaderNavigationTarget}"
                                                                                        IsVisible="{Binding HasPixelShaderNavigationTarget}"
                                                                                        Click="BlockStreamNavigationButton_Click" />
                                                                            </Grid>

                                                                            <Grid ColumnDefinitions="100,*"
                                                                                  ColumnSpacing="10">
                                                                                <TextBlock Classes="techsetPassLabel"
                                                                                           Text="Arguments" />
                                                                                <TextBlock Grid.Column="1"
                                                                                           Classes="techsetPassValue"
                                                                                           IsVisible="{Binding HasNoArgumentsNavigationTarget}"
                                                                                           Text="{Binding Arguments}" />
                                                                                <Button Grid.Column="1"
                                                                                        Classes="blockStreamNavigationLabel"
                                                                                        Content="{Binding ArgumentsNavigationValue}"
                                                                                        Tag="{Binding ArgumentsNavigationTarget}"
                                                                                        IsVisible="{Binding HasArgumentsNavigationTarget}"
                                                                                        Click="BlockStreamNavigationButton_Click" />
                                                                            </Grid>

                                                                            <Grid ColumnDefinitions="100,*"
                                                                                  ColumnSpacing="10">
                                                                                <TextBlock Classes="techsetPassLabel"
                                                                                           Text="Flags/Precompiled" />
                                                                                <TextBlock Grid.Column="1"
                                                                                           Classes="techsetPassValue"
                                                                                           Text="{Binding FlagsAndPrecompiled}" />
                                                                            </Grid>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock x:Name="TechsetTechniquesEmptyTextBlock"
                                           Grid.Row="1"
                                           Classes="techsetSecondary"
                                           Text="No techniques were loaded for this techset."
                                           HorizontalAlignment="Center"
                                           Margin="0,14"
                                           IsVisible="False" />
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
