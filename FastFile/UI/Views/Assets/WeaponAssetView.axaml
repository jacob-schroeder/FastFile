<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:models="clr-namespace:UI.Models"
             x:Class="UI.Views.Assets.WeaponAssetView">
    <UserControl.Styles>
        <Style Selector="TextBlock.weaponTitle">
            <Setter Property="Foreground" Value="#F4F4F5" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBlock.weaponMeta">
            <Setter Property="Foreground" Value="#C7C9D1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style Selector="TextBlock.weaponSectionTitle">
            <Setter Property="Foreground" Value="#F4F4F5" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBlock.weaponKey">
            <Setter Property="Foreground" Value="#9DA1AA" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBlock.weaponValue">
            <Setter Property="Foreground" Value="#E5E7EB" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style Selector="TextBlock.weaponSecondary">
            <Setter Property="Foreground" Value="#AEB2BB" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style Selector="Border.weaponPanel">
            <Setter Property="Background" Value="#252629" />
            <Setter Property="BorderBrush" Value="#3C3F44" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="0" />
        </Style>

        <Style Selector="Border.weaponHeader">
            <Setter Property="Background" Value="#2B2D30" />
            <Setter Property="BorderBrush" Value="#3C3F44" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="12,10" />
        </Style>

        <Style Selector="Border.weaponValueRow">
            <Setter Property="BorderBrush" Value="#34373D" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="12,8" />
        </Style>

        <Style Selector="Button.weaponAction">
            <Setter Property="Background" Value="#303238" />
            <Setter Property="BorderBrush" Value="#4E5157" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Foreground" Value="#F4F4F5" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*"
          Background="#1E1F22">
        <Border Padding="14,12"
                Background="#252629"
                BorderBrush="#3C3F44"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto,Auto"
                  ColumnSpacing="12">
                <StackPanel Spacing="3">
                    <TextBlock x:Name="WeaponNameTextBlock"
                               Classes="weaponTitle" />
                    <TextBlock x:Name="WeaponSummaryTextBlock"
                               Classes="weaponMeta" />
                </StackPanel>

                <Button x:Name="ViewXModelButton"
                        Grid.Column="1"
                        Classes="weaponAction"
                        Click="ViewXModelButton_Click"
                        VerticalAlignment="Center">
                    <Grid ColumnDefinitions="Auto,Auto"
                          ColumnSpacing="7">
                        <materialIcons:MaterialIcon Width="15"
                                                    Height="15"
                                                    Foreground="#F4F4F5"
                                                    Kind="CubeOutline" />
                        <TextBlock Grid.Column="1"
                                   Text="View 3D Model"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Button>

                <TextBlock x:Name="WeaponOffsetTextBlock"
                           Grid.Column="2"
                           Classes="weaponMeta"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <Grid Margin="14"
                  RowDefinitions="Auto">
                <Border Classes="weaponPanel">
                    <Grid RowDefinitions="Auto,*">
                        <Border Classes="weaponHeader">
                            <TextBlock Classes="weaponSectionTitle"
                                       Text="Weapon Variant Details" />
                        </Border>

                        <ItemsControl x:Name="WeaponSummaryItemsControl"
                                      Grid.Row="1">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:KeyValueListItem">
                                    <Border Classes="weaponValueRow">
                                        <Grid ColumnDefinitions="Auto,*"
                                              ColumnSpacing="12">
                                            <TextBlock Classes="weaponKey"
                                                       Text="{Binding Key}" />
                                            <TextBlock Grid.Column="1"
                                                       Classes="weaponValue"
                                                       IsVisible="{Binding HasNoNavigationTarget}"
                                                       Text="{Binding Value}" />
                                            <Button Grid.Column="1"
                                                    Classes="blockStreamNavigationLabel"
                                                    Content="{Binding NavigationValue}"
                                                    Tag="{Binding NavigationTarget}"
                                                    IsVisible="{Binding HasNavigationTarget}"
                                                    Click="BlockStreamNavigationButton_Click" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
