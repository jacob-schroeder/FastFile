<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:UI.Models"
             x:Class="UI.Views.Assets.MaterialAssetView">
    <UserControl.Styles>
        <Style Selector="TextBlock.materialAssetTitle">
            <Setter Property="Foreground" Value="#F4F4F5" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style Selector="TextBlock.materialAssetMeta">
            <Setter Property="Foreground" Value="#C7C9D1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style Selector="TextBlock.materialSectionTitle">
            <Setter Property="Foreground" Value="#F4F4F5" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBlock.materialKey">
            <Setter Property="Foreground" Value="#9DA1AA" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBlock.materialValue">
            <Setter Property="Foreground" Value="#E5E7EB" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style Selector="TextBlock.textureTitle">
            <Setter Property="Foreground" Value="#F4F4F5" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style Selector="TextBlock.textureMeta">
            <Setter Property="Foreground" Value="#AEB2BB" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style Selector="Border.materialPanel">
            <Setter Property="Background" Value="#252629" />
            <Setter Property="BorderBrush" Value="#3C3F44" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="0" />
        </Style>

        <Style Selector="Border.materialHeader">
            <Setter Property="Background" Value="#2B2D30" />
            <Setter Property="BorderBrush" Value="#3C3F44" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="12,10" />
        </Style>

        <Style Selector="Border.materialValueRow">
            <Setter Property="BorderBrush" Value="#34373D" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="12,8" />
        </Style>

        <Style Selector="Border.textureCard">
            <Setter Property="Background" Value="#252629" />
            <Setter Property="BorderBrush" Value="#3C3F44" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*"
          Background="#1E1F22">
        <Border Padding="14,12"
                Background="#252629"
                BorderBrush="#3C3F44"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="12">
                <StackPanel Spacing="3">
                    <TextBlock x:Name="MaterialNameTextBlock"
                               Classes="materialAssetTitle" />
                    <TextBlock x:Name="MaterialSubtitleTextBlock"
                               Classes="materialAssetMeta" />
                </StackPanel>

                <TextBlock x:Name="MaterialTextureCountTextBlock"
                           Grid.Column="1"
                           Classes="materialAssetMeta"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
            <Grid Margin="14"
                  RowDefinitions="Auto,Auto,Auto"
                  RowSpacing="12">
                <Border Classes="materialPanel">
                    <Grid RowDefinitions="Auto,*">
                        <Border Classes="materialHeader">
                            <TextBlock Classes="materialSectionTitle"
                                       Text="Material" />
                        </Border>

                        <ItemsControl x:Name="MaterialDetailsItemsControl"
                                      Grid.Row="1">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:KeyValueListItem">
                                    <Border Classes="materialValueRow">
                                        <Grid ColumnDefinitions="Auto,*"
                                              ColumnSpacing="12">
                                            <TextBlock Classes="materialKey"
                                                       Text="{Binding Key}" />
                                            <TextBlock Grid.Column="1"
                                                       Classes="materialValue"
                                                       Text="{Binding Value}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Classes="materialPanel">
                    <Grid RowDefinitions="Auto,*">
                        <Border Classes="materialHeader">
                            <TextBlock Classes="materialSectionTitle"
                                       Text="Textures" />
                        </Border>

                        <ItemsControl x:Name="MaterialTexturesItemsControl"
                                      Grid.Row="1"
                                      Margin="12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:MaterialTextureDisplayItem">
                                    <Border Classes="textureCard">
                                        <Grid ColumnDefinitions="168,*"
                                              ColumnSpacing="12"
                                              MinHeight="150">
                                            <Border Background="#18191C"
                                                    BorderBrush="#34373D"
                                                    BorderThickness="0,0,1,0"
                                                    ClipToBounds="True">
                                                <Grid>
                                                    <Image Source="{Binding Preview}"
                                                           Stretch="Uniform"
                                                           Margin="8"
                                                           IsVisible="{Binding HasPreview}" />
                                                    <TextBlock Text="No inline preview"
                                                               Foreground="#8F949E"
                                                               FontSize="12"
                                                               TextAlignment="Center"
                                                               TextWrapping="Wrap"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Margin="12"
                                                               IsVisible="{Binding HasNoPreview}" />
                                                </Grid>
                                            </Border>

                                            <Grid Grid.Column="1"
                                                  RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                                                  RowSpacing="6"
                                                  Margin="0,10,12,10">
                                                <Grid ColumnDefinitions="*,Auto"
                                                      ColumnSpacing="12">
                                                    <TextBlock Classes="textureTitle"
                                                               Text="{Binding ImageName}" />
                                                    <TextBlock Grid.Column="1"
                                                               Classes="textureMeta"
                                                               Text="{Binding Index}" />
                                                </Grid>

                                                <TextBlock Grid.Row="1"
                                                           Classes="textureMeta"
                                                           Text="{Binding Semantic}" />
                                                <TextBlock Grid.Row="2"
                                                           Classes="textureMeta"
                                                           Text="{Binding ImageSize}" />
                                                <TextBlock Grid.Row="3"
                                                           Classes="textureMeta"
                                                           Text="{Binding Format}" />
                                                <TextBlock Grid.Row="4"
                                                           Classes="textureMeta"
                                                           Text="{Binding Status}" />
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Classes="materialPanel">
                    <Grid RowDefinitions="Auto,*">
                        <Border Classes="materialHeader">
                            <TextBlock Classes="materialSectionTitle"
                                       Text="Constants" />
                        </Border>

                        <ItemsControl x:Name="MaterialConstantsItemsControl"
                                      Grid.Row="1">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:MaterialConstantDisplayItem">
                                    <Border Classes="materialValueRow">
                                        <Grid ColumnDefinitions="220,140,*"
                                              ColumnSpacing="12">
                                            <TextBlock Classes="materialKey"
                                                       Text="{Binding Name}" />
                                            <TextBlock Grid.Column="1"
                                                       Classes="materialValue"
                                                       Text="{Binding NameHash}" />
                                            <TextBlock Grid.Column="2"
                                                       Classes="materialValue"
                                                       Text="{Binding Value}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
