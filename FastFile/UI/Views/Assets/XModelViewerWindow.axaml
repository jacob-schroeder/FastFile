<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:assets="clr-namespace:UI.Views.Assets"
        x:Class="UI.Views.Assets.XModelViewerWindow"
        Title="XModel Viewer"
        Width="1080"
        Height="760"
        MinWidth="820"
        MinHeight="560"
        Background="#1E1F22"
        WindowStartupLocation="CenterOwner">
    <assets:XModelViewer x:Name="ViewerContent" />
</Window>
