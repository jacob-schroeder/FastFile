<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:UI.Models"
             x:Class="UI.Views.Assets.MenuListAssetView">
    <UserControl.Styles>
        <Style Selector="TextBlock.menuListTitle">
            <Setter Property="Foreground" Value="#F4F4F5" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="TextBlock.menuListMeta">
            <Setter Property="Foreground" Value="#C7C9D1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="TextBlock.menuListColumnHeader">
            <Setter Property="Foreground" Value="#C7C9D1" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="TextBlock.menuListCell">
            <Setter Property="Foreground" Value="#F4F4F5" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="TextBlock.menuListMutedCell">
            <Setter Property="Foreground" Value="#9DA1AA" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="Button.menuListRowButton">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Button.menuListRowButton:pointerover">
            <Setter Property="Background" Value="#2B2D30" />
        </Style>

        <Style Selector="Button.menuListRowButton:disabled">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*"
          Background="#1E1F22">
        <Border Padding="14,12"
                Background="#252629"
                BorderBrush="#3C3F44"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="12">
                <TextBlock x:Name="MenuListNameTextBlock"
                           Classes="menuListTitle" />

                <TextBlock x:Name="MenuListCountTextBlock"
                           Grid.Column="1"
                           Classes="menuListMeta" />
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <ScrollViewer x:Name="MenuListTableScrollViewer"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Padding="12,8"
                            Background="#2B2D30"
                            BorderBrush="#3C3F44"
                            BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="52,320,90,90,160,120,160"
                              ColumnSpacing="12">
                            <TextBlock Classes="menuListColumnHeader" Text="#" />
                            <TextBlock Grid.Column="1" Classes="menuListColumnHeader" Text="Name" />
                            <TextBlock Grid.Column="2" Classes="menuListColumnHeader" Text="Items" />
                            <TextBlock Grid.Column="3" Classes="menuListColumnHeader" Text="Fullscreen" />
                            <TextBlock Grid.Column="4" Classes="menuListColumnHeader" Text="Font" />
                            <TextBlock Grid.Column="5" Classes="menuListColumnHeader" Text="Rect" />
                            <TextBlock Grid.Column="6" Classes="menuListColumnHeader" Text="Pointer" />
                        </Grid>
                    </Border>

                    <ItemsControl x:Name="MenusItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:MenuListMenuDisplayItem">
                                <Border BorderBrush="#3C3F44"
                                        BorderThickness="0,0,0,1"
                                        Padding="12,8">
                                    <Button Classes="menuListRowButton"
                                            Tag="{Binding}"
                                            IsEnabled="{Binding CanOpen}"
                                            Click="MenuRow_Click">
                                        <Grid ColumnDefinitions="52,320,90,90,160,120,160"
                                              ColumnSpacing="12">
                                            <TextBlock Classes="menuListMutedCell"
                                                       Text="{Binding Index}" />
                                            <TextBlock Grid.Column="1"
                                                       Classes="menuListCell"
                                                       Text="{Binding Name}" />
                                            <TextBlock Grid.Column="2"
                                                       Classes="menuListCell"
                                                       Text="{Binding ItemCount}" />
                                            <TextBlock Grid.Column="3"
                                                       Classes="menuListCell"
                                                       Text="{Binding Fullscreen}" />
                                            <TextBlock Grid.Column="4"
                                                       Classes="menuListMutedCell"
                                                       Text="{Binding Font}" />
                                            <TextBlock Grid.Column="5"
                                                       Classes="menuListMutedCell"
                                                       Text="{Binding Rect}" />
                                            <TextBlock Grid.Column="6"
                                                       Classes="menuListMutedCell"
                                                       Text="{Binding Pointer}" />
                                        </Grid>
                                    </Button>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <TextBlock x:Name="MenuListEmptyTextBlock"
                       Foreground="#9DA1AA"
                       FontSize="13"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       IsVisible="False"
                       Text="No menus available." />
        </Grid>
    </Grid>
</UserControl>
