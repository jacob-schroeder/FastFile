<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:UI.Models"
             x:Class="UI.Views.Assets.StringTableAssetView">
    <ListBox x:Name="StringTableRowsListBox"
             Background="#1E1F22"
             BorderThickness="0"
             Padding="0"
             ScrollViewer.HorizontalScrollBarVisibility="Auto"
             ScrollViewer.VerticalScrollBarVisibility="Auto">
        <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
                <VirtualizingStackPanel />
            </ItemsPanelTemplate>
        </ListBox.ItemsPanel>

        <ListBox.ItemTemplate>
            <DataTemplate x:DataType="models:StringTableRowDisplayItem">
                <ItemsControl ItemsSource="{Binding Cells}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:StringTableCellDisplayItem">
                            <Border BorderBrush="#3C3F44"
                                    BorderThickness="0,0,1,1">
                                <TextBox AcceptsReturn="False"
                                         BorderThickness="0"
                                         MinHeight="30"
                                         Padding="8,4"
                                         Text="{Binding Value, Mode=TwoWay}"
                                         TextWrapping="NoWrap"
                                         VerticalContentAlignment="Center"
                                         Width="180" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DataTemplate>
        </ListBox.ItemTemplate>
    </ListBox>
</UserControl>
