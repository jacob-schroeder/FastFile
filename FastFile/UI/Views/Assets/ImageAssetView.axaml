<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:UI.Models"
             x:Class="UI.Views.Assets.ImageAssetView">
    <UserControl.Styles>
        <Style Selector="TextBlock.imageAssetTitle">
            <Setter Property="Foreground" Value="#F4F4F5" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style Selector="TextBlock.imageAssetMeta">
            <Setter Property="Foreground" Value="#C7C9D1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style Selector="TextBlock.imageAssetSectionTitle">
            <Setter Property="Foreground" Value="#F4F4F5" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBlock.imageAssetKey">
            <Setter Property="Foreground" Value="#9DA1AA" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBlock.imageAssetValue">
            <Setter Property="Foreground" Value="#E5E7EB" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style Selector="Border.imageAssetPanel">
            <Setter Property="Background" Value="#252629" />
            <Setter Property="BorderBrush" Value="#3C3F44" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="0" />
        </Style>

        <Style Selector="Border.imageAssetHeader">
            <Setter Property="Background" Value="#2B2D30" />
            <Setter Property="BorderBrush" Value="#3C3F44" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="12,10" />
        </Style>

        <Style Selector="Border.imageAssetValueRow">
            <Setter Property="BorderBrush" Value="#34373D" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="12,8" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*"
          Background="#1E1F22">
        <Border Padding="14,12"
                Background="#252629"
                BorderBrush="#3C3F44"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="12">
                <StackPanel Spacing="3">
                    <TextBlock x:Name="ImageNameTextBlock"
                               Classes="imageAssetTitle" />
                    <TextBlock x:Name="ImageSubtitleTextBlock"
                               Classes="imageAssetMeta" />
                </StackPanel>

                <TextBlock x:Name="ImageFormatTextBlock"
                           Grid.Column="1"
                           Classes="imageAssetMeta"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <Grid Margin="14"
                  RowDefinitions="Auto,Auto"
                  RowSpacing="12">
                <Border Classes="imageAssetPanel">
                    <Grid RowDefinitions="Auto,*">
                        <Border Classes="imageAssetHeader">
                            <TextBlock Classes="imageAssetSectionTitle"
                                       Text="Preview" />
                        </Border>

                        <Border Grid.Row="1"
                                Height="420"
                                Background="#18191C"
                                ClipToBounds="True">
                            <Grid>
                                <Image x:Name="ImagePreview"
                                       Stretch="Uniform"
                                       Margin="12"
                                       IsVisible="False" />
                                <TextBlock x:Name="ImageUnavailableTextBlock"
                                           Foreground="#9DA1AA"
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           MaxWidth="520" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Classes="imageAssetPanel">
                    <Grid RowDefinitions="Auto,*">
                        <Border Classes="imageAssetHeader">
                            <TextBlock Classes="imageAssetSectionTitle"
                                       Text="Image Data" />
                        </Border>

                        <ItemsControl x:Name="ImageDetailsItemsControl"
                                      Grid.Row="1">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:KeyValueListItem">
                                    <Border Classes="imageAssetValueRow">
                                        <Grid ColumnDefinitions="Auto,*"
                                              ColumnSpacing="12">
                                            <TextBlock Classes="imageAssetKey"
                                                       Text="{Binding Key}" />
                                            <TextBlock Grid.Column="1"
                                                       Classes="imageAssetValue"
                                                       Text="{Binding Value}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
