<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:menu="clr-namespace:UI.Components.Menu"
             xmlns:models="clr-namespace:UI.Models"
             x:Class="UI.Components.Menu.MenuController">
    <UserControl.Styles>
        <Style Selector="TextBlock.menuDetailsTitle">
            <Setter Property="Foreground" Value="#F4F4F5" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style Selector="TextBlock.menuDetailsSubtitle">
            <Setter Property="Foreground" Value="#AEB2BB" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style Selector="TextBlock.menuDetailsSectionTitle">
            <Setter Property="Foreground" Value="#F4F4F5" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="Border.menuDetailsPanel">
            <Setter Property="Background" Value="#252629" />
            <Setter Property="BorderBrush" Value="#3C3F44" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="0" />
        </Style>

        <Style Selector="Border.menuDetailsHeader">
            <Setter Property="Background" Value="#2B2D30" />
            <Setter Property="BorderBrush" Value="#3C3F44" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="12,10" />
        </Style>

        <Style Selector="TextBlock.menuDetailsKey">
            <Setter Property="Foreground" Value="#9DA1AA" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="TextBlock.menuDetailsValue">
            <Setter Property="Foreground" Value="#E5E7EB" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="Button.menuDetailsViewButton">
            <Setter Property="Background" Value="#9E3A3F" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#DB5860" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="Button.menuDetailsViewButton:pointerover">
            <Setter Property="Background" Value="#B84950" />
        </Style>

        <Style Selector="Border.menuDetailsValueRow">
            <Setter Property="BorderBrush" Value="#34373D" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="12,8" />
        </Style>

        <Style Selector="Border.menuDetailsBadge">
            <Setter Property="Background" Value="#9E3A3F" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="CornerRadius" Value="999" />
        </Style>

        <Style Selector="TextBlock.menuDetailsBadgeText">
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBlock.menuInsightName">
            <Setter Property="Foreground" Value="#F4F4F5" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style Selector="TextBlock.menuInsightSummary">
            <Setter Property="Foreground" Value="#DADCE3" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontFamily" Value="Courier New" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style Selector="TextBlock.menuInsightDetail">
            <Setter Property="Foreground" Value="#AEB2BB" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontFamily" Value="Courier New" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style Selector="Border.menuInsightRow">
            <Setter Property="BorderBrush" Value="#34373D" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="12,10" />
        </Style>

        <Style Selector="TabControl.menuDetailsTabs">
            <Setter Property="Background" Value="#1E1F22" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*"
          Background="#1E1F22">
        <Border Padding="14,12"
                Background="#252629"
                BorderBrush="#3C3F44"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="12">
                <StackPanel Spacing="3">
                    <TextBlock x:Name="MenuNameTextBlock"
                               Classes="menuDetailsTitle" />
                    <TextBlock x:Name="MenuSubtitleTextBlock"
                               Classes="menuDetailsSubtitle" />
                </StackPanel>

                <Border Grid.Column="1"
                        Classes="menuDetailsBadge"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="MenuItemCountTextBlock"
                               Classes="menuDetailsBadgeText" />
                </Border>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <Grid Margin="14"
                  RowDefinitions="Auto,Auto,*"
                  ColumnDefinitions="3*,2*"
                  RowSpacing="12"
                  ColumnSpacing="12">
                <Border Grid.ColumnSpan="2"
                        Classes="menuDetailsPanel">
                    <Grid RowDefinitions="Auto,*">
                        <Border Classes="menuDetailsHeader">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="12">
                                <TextBlock Classes="menuDetailsSectionTitle"
                                           Text="Window Preview" />
                                <CheckBox x:Name="ShowConditionalItemsCheckBox"
                                          Grid.Column="1"
                                          Content="Show conditional"
                                          Foreground="#C7C9D1"
                                          FontSize="12"
                                          VerticalAlignment="Center"
                                          IsChecked="False"
                                          IsCheckedChanged="ShowConditionalItemsCheckBox_Changed" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="1"
                                Height="360"
                                Background="#18191C"
                                ClipToBounds="True">
                            <Viewbox Stretch="Uniform">
                                <Canvas x:Name="MenuPreviewCanvas"
                                        Width="640"
                                        Height="480"
                                        ClipToBounds="True" />
                            </Viewbox>
                        </Border>
                    </Grid>
                </Border>

                <TabControl Grid.Row="1"
                            Grid.ColumnSpan="2"
                            Classes="menuDetailsTabs">
                    <TabItem Header="Overview">
                        <Grid ColumnDefinitions="3*,2*"
                              ColumnSpacing="12"
                              Margin="0,12,0,0">
                            <Border Classes="menuDetailsPanel">
                                <Grid RowDefinitions="Auto,*">
                                    <Border Classes="menuDetailsHeader">
                                        <TextBlock Classes="menuDetailsSectionTitle"
                                                   Text="Menu" />
                                    </Border>

                                    <ItemsControl x:Name="MenuDetailsItemsControl"
                                                  Grid.Row="1">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:KeyValueListItem">
                                                <Border Classes="menuDetailsValueRow">
                                                    <Grid ColumnDefinitions="Auto,*"
                                                          ColumnSpacing="12">
                                                        <TextBlock Classes="menuDetailsKey"
                                                                   Text="{Binding Key}" />
                                                        <TextBlock Grid.Column="1"
                                                                   Classes="menuDetailsValue"
                                                                   Text="{Binding Value}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>

                            <Border Grid.Column="1"
                                    Classes="menuDetailsPanel">
                                <Grid RowDefinitions="Auto,*">
                                    <Border Classes="menuDetailsHeader">
                                        <TextBlock Classes="menuDetailsSectionTitle"
                                                   Text="Window" />
                                    </Border>

                                    <ItemsControl x:Name="WindowDetailsItemsControl"
                                                  Grid.Row="1">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="menu:MenuMaterialReferenceDisplayItem">
                                                <Border Classes="menuDetailsValueRow">
                                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                                          ColumnSpacing="12">
                                                        <TextBlock Classes="menuDetailsKey"
                                                                   Text="{Binding Key}" />
                                                        <TextBlock Grid.Column="1"
                                                                   Classes="menuDetailsValue"
                                                                   Text="{Binding Value}" />
                                                        <Button Grid.Column="2"
                                                                Classes="menuDetailsViewButton"
                                                                Content="View"
                                                                Tag="{Binding Material}"
                                                                IsVisible="{Binding CanOpenMaterial}"
                                                                Click="MaterialViewButton_Click" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Behavior">
                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="12"
                              Margin="0,12,0,0">
                            <Border Classes="menuDetailsPanel">
                                <Grid RowDefinitions="Auto,*">
                                    <Border Classes="menuDetailsHeader">
                                        <TextBlock Classes="menuDetailsSectionTitle"
                                                   Text="Event Handlers" />
                                    </Border>

                                    <ItemsControl x:Name="MenuEventsItemsControl"
                                                  Grid.Row="1">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="menu:MenuInsightDisplayItem">
                                                <Border Classes="menuInsightRow">
                                                    <StackPanel Spacing="5">
                                                        <TextBlock Classes="menuInsightName"
                                                                   Text="{Binding Name}" />
                                                        <TextBlock Classes="menuInsightSummary"
                                                                   Text="{Binding Summary}" />
                                                        <TextBlock Classes="menuInsightDetail"
                                                                   IsVisible="{Binding HasDetail}"
                                                                   Text="{Binding Detail}" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>

                            <Border Grid.Column="1"
                                    Classes="menuDetailsPanel">
                                <Grid RowDefinitions="Auto,*">
                                    <Border Classes="menuDetailsHeader">
                                        <TextBlock Classes="menuDetailsSectionTitle"
                                                   Text="Menu Expressions" />
                                    </Border>

                                    <ItemsControl x:Name="MenuExpressionsItemsControl"
                                                  Grid.Row="1">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="menu:MenuInsightDisplayItem">
                                                <Border Classes="menuInsightRow">
                                                    <StackPanel Spacing="5">
                                                        <TextBlock Classes="menuInsightName"
                                                                   Text="{Binding Name}" />
                                                        <TextBlock Classes="menuInsightSummary"
                                                                   Text="{Binding Summary}" />
                                                        <TextBlock Classes="menuInsightDetail"
                                                                   IsVisible="{Binding HasDetail}"
                                                                   Text="{Binding Detail}" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Items">
                        <Border Margin="0,12,0,0"
                                Classes="menuDetailsPanel">
                            <Grid RowDefinitions="Auto,*">
                                <Border Classes="menuDetailsHeader">
                                    <TextBlock Classes="menuDetailsSectionTitle"
                                               Text="Items" />
                                </Border>

                                <ItemsControl x:Name="MenuItemsItemsControl"
                                              Grid.Row="1">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="menu:MenuItemDefDisplayItem">
                                            <menu:MenuItemDefController />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock x:Name="MenuItemsEmptyTextBlock"
                                           Grid.Row="1"
                                           Margin="0,24"
                                           Foreground="#9DA1AA"
                                           FontSize="13"
                                           HorizontalAlignment="Center"
                                           IsVisible="False"
                                           Text="No items available." />
                            </Grid>
                        </Border>
                    </TabItem>
                </TabControl>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
