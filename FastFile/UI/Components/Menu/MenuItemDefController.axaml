<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:menu="clr-namespace:UI.Components.Menu"
             x:Class="UI.Components.Menu.MenuItemDefController"
             x:DataType="menu:MenuItemDefDisplayItem">
    <UserControl.Styles>
        <Style Selector="TextBlock.menuItemIndex">
            <Setter Property="Foreground" Value="#DB5860" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>

        <Style Selector="TextBlock.menuItemTitle">
            <Setter Property="Foreground" Value="#F4F4F5" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style Selector="TextBlock.menuItemMeta">
            <Setter Property="Foreground" Value="#AEB2BB" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style Selector="TextBlock.menuItemLabel">
            <Setter Property="Foreground" Value="#8F949E" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBlock.menuItemValue">
            <Setter Property="Foreground" Value="#DADCE3" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style Selector="TextBlock.menuItemAction">
            <Setter Property="Foreground" Value="#DB5860" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="Button.menuItemRowButton">
            <Setter Property="Background" Value="#252629" />
            <Setter Property="BorderBrush" Value="#3C3F44" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>

        <Style Selector="Button.menuItemRowButton:pointerover">
            <Setter Property="Background" Value="#2B2D30" />
            <Setter Property="BorderBrush" Value="#DB5860" />
        </Style>

        <Style Selector="Button.menuItemRowButton:disabled">
            <Setter Property="Opacity" Value="0.65" />
        </Style>
    </UserControl.Styles>

    <Button Classes="menuItemRowButton"
            Tag="{Binding}"
            Click="MenuItemRow_Click"
            IsEnabled="{Binding CanOpen}">
        <Grid ColumnDefinitions="44,2*,*,*,*,Auto"
              ColumnSpacing="14">
            <TextBlock Classes="menuItemIndex"
                       Text="{Binding Index}" />

            <StackPanel Grid.Column="1"
                        Spacing="4">
                <TextBlock Classes="menuItemTitle"
                           Text="{Binding Name}" />
                <TextBlock Classes="menuItemMeta"
                           Text="{Binding Text}" />
            </StackPanel>

            <Grid Grid.Column="2"
                  RowDefinitions="Auto,Auto"
                  RowSpacing="3">
                <TextBlock Classes="menuItemLabel"
                           Text="Type / Data" />
                <TextBlock Grid.Row="1"
                           Classes="menuItemValue"
                           Text="{Binding Type}" />
            </Grid>

            <Grid Grid.Column="3"
                  RowDefinitions="Auto,Auto"
                  RowSpacing="3">
                <TextBlock Classes="menuItemLabel"
                           Text="Rect" />
                <TextBlock Grid.Row="1"
                           Classes="menuItemValue"
                           Text="{Binding Rect}" />
            </Grid>

            <Grid Grid.Column="4"
                  RowDefinitions="Auto,Auto"
                  RowSpacing="3">
                <TextBlock Classes="menuItemLabel"
                           Text="Dvar" />
                <TextBlock Grid.Row="1"
                           Classes="menuItemValue"
                           Text="{Binding Dvar}" />
            </Grid>

            <TextBlock Grid.Column="5"
                       Classes="menuItemAction"
                       Text="Details" />
        </Grid>
    </Button>
</UserControl>
